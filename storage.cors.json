[
  {
    "origin": [
      "http://localhost:5173",
      "http://localhost:3000",
      "https://*.vercel.app"
    ],
    "method": ["DELETE", "GET", "HEAD", "POST", "PUT"],
    "responseHeader": [
      "Authorization",
      "Content-Type",
      "Content-Length",
      "Content-Range",
      "Accept-Ranges",
      "Range",
      "Date",
      "ETag",
      "x-goog-resumable"
    ],
    "maxAgeSeconds": 3600
  }
]
