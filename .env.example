# Copy this file to `.env` and fill in real values.
# `.env` is loaded via `docker run --env-file .env` (and locally via `dotenv`).

# ----- Server -----
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Comma-separated origins always allowed in CORS (vercel.app + localhost are
# auto-allowed regardless of this list).
ALLOWED_ORIGINS=https://cozie-cs.vercel.app,https://cozie-kohl.vercel.app

# ----- Auth -----
# Use a long, random string. Minimum 16 characters enforced by env validator.
JWT_SECRET=replace-with-a-long-random-string-32chars+
JWT_EXPIRES_IN=7d

# ----- Backend Firebase Admin (service account) -----
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# IMPORTANT: when used with `docker run --env-file`, the value must be on one
# line with literal \n in place of real newlines. The code does
# `.replace(/\\n/g, "\n")` before passing it to firebase-admin.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...your...key...here...\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=1234567890

# ----- Frontend Firebase project (optional, used for signed URLs / storage) -----
# Whole service-account JSON on ONE line (escape inner quotes if needed).
# FRONTEND_FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}
# FRONTEND_STORAGE_BUCKET=your-project-id.appspot.com

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@your-domain.com
EMAIL_USER=

# ----- Rate limiting (override defaults if needed) -----
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=20
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=300
